---
- name: Manage persistent UBI 9 systemd container
  hosts: all
  become: true
  gather_facts: true

  vars:
    systemd_container_name: "ansible2.example.com"
    systemd_container_hostname: "ansible2.example.com"
    systemd_container_image: "redhat/ubi9:latest"

    container_ansible_user: "ansible"
    container_ansible_password: "ansible"
    container_ansible_sudoers_file: "/etc/sudoers.d/ansible"

    # Use obfuscated variable for SSH username
    ansible_user: "{{ robert_of_loxley }}"
    ansible_ssh_user: "{{ robert_of_loxley }}"   # legacy alias

    # Use obfuscated variable for SSH authentication
    ansible_password: "{{ give_to_the_poor }}"
    ansible_ssh_pass: "{{ give_to_the_poor }}"   # legacy alias

  roles:
    - resolve_and_set_inventory_ip_addresses

  tasks:
    - name: Ensure required Docker Python SDK is available
      ansible.builtin.package:
        name: python3-docker
        state: present
      register: docker_python_sdk_install_result
      ignore_errors: true

    - name: Pull UBI 9 container image
      community.docker.docker_image:
        name: "{{ systemd_container_image }}"
        source: pull
      register: ubi9_image_pull_result
      ignore_errors: true

    - name: Check whether the systemd container already exists
      community.docker.docker_container_info:
        name: "{{ systemd_container_name }}"
      register: systemd_container_info
      failed_when: false

    - name: Start existing systemd container with intended runtime definition
      community.docker.docker_container:
        name: "{{ systemd_container_name }}"
        image: "{{ systemd_container_image }}"
        hostname: "{{ systemd_container_hostname }}"
        state: started
        detach: true
        auto_remove: false
        privileged: true
        command: /usr/sbin/init
        restart_policy: "no"
        cgroupns_mode: host
        volumes:
          - /sys/fs/cgroup:/sys/fs/cgroup:rw
        tmpfs:
          - /run
          - /tmp
        env:
          container: docker
        recreate: false
      when:
        - systemd_container_info.exists | default(false)
      register: existing_container_start_result
      ignore_errors: true

    - name: Re-check existing container state after start attempt
      community.docker.docker_container_info:
        name: "{{ systemd_container_name }}"
      register: systemd_container_after_start_info
      failed_when: false
      when:
        - systemd_container_info.exists | default(false)

    - name: Remove existing container if it failed to remain running
      community.docker.docker_container:
        name: "{{ systemd_container_name }}"
        state: absent
        force_kill: true
      when:
        - systemd_container_info.exists | default(false)
        - not systemd_container_after_start_info.container.State.Running | default(false)

    - name: Create and start systemd container if it does not exist or was remediated
      community.docker.docker_container:
        name: "{{ systemd_container_name }}"
        image: "{{ systemd_container_image }}"
        hostname: "{{ systemd_container_hostname }}"
        state: started
        detach: true
        auto_remove: false
        privileged: true
        command: /usr/sbin/init
        restart_policy: "no"
        cgroupns_mode: host
        volumes:
          - /sys/fs/cgroup:/sys/fs/cgroup:rw
        tmpfs:
          - /run
          - /tmp
        env:
          container: docker
      when:
        - >
          not systemd_container_info.exists | default(false)
          or
          not systemd_container_after_start_info.container.State.Running | default(false)

    - name: Final check of systemd container state before hostname, user, and sshd configuration
      community.docker.docker_container_info:
        name: "{{ systemd_container_name }}"
      register: systemd_container_final_info
      failed_when: false

    - name: Wait for systemd to become responsive inside the container
      community.docker.docker_container_exec:
        container: "{{ systemd_container_name }}"
        command: >-
          /bin/bash -lc
          'for i in {1..30}; do
             systemctl list-units --type=service >/dev/null 2>&1 && exit 0;
             sleep 1;
           done;
           exit 1'
      register: container_systemd_ready_result
      when:
        - systemd_container_final_info.exists | default(false)
        - systemd_container_final_info.container.State.Running | default(false)
      changed_when: false
      failed_when: false

    - name: Set hostname inside running systemd container
      community.docker.docker_container_exec:
        container: "{{ systemd_container_name }}"
        command: "hostnamectl set-hostname {{ systemd_container_hostname }}"
      register: container_hostnamectl_result
      when:
        - systemd_container_final_info.exists | default(false)
        - systemd_container_final_info.container.State.Running | default(false)
      failed_when: false
      changed_when: container_hostnamectl_result.rc | default(1) == 0

    - name: Verify hostname inside running container
      community.docker.docker_container_exec:
        container: "{{ systemd_container_name }}"
        command: "hostnamectl --static"
      register: container_hostname_verify_result
      when:
        - systemd_container_final_info.exists | default(false)
        - systemd_container_final_info.container.State.Running | default(false)
      failed_when: false
      changed_when: false

    - name: Install sudo and user-management packages inside the systemd container
      community.docker.docker_container_exec:
        container: "{{ systemd_container_name }}"
        command: >-
          /bin/bash -lc
          'missing_packages="";
           rpm -q sudo >/dev/null 2>&1 || missing_packages="$missing_packages sudo";
           rpm -q shadow-utils >/dev/null 2>&1 || missing_packages="$missing_packages shadow-utils";
           if [ -n "$missing_packages" ]; then
             dnf -y install $missing_packages;
             echo "sudo/user-management packages installed";
           else
             echo "sudo/user-management packages already installed";
           fi'
      register: container_sudo_user_tools_result
      when:
        - systemd_container_final_info.exists | default(false)
        - systemd_container_final_info.container.State.Running | default(false)
      changed_when: "'sudo/user-management packages installed' in container_sudo_user_tools_result.stdout"
      failed_when: container_sudo_user_tools_result.rc | default(1) != 0

    - name: Create ansible user with wheel membership and passwordless sudo inside the container
      community.docker.docker_container_exec:
        container: "{{ systemd_container_name }}"
        command: >-
          /bin/bash -lc
          'set -e;

           changed=0;

           if ! getent group wheel >/dev/null 2>&1; then
             groupadd wheel;
             changed=1;
           fi;

           if ! id -u "{{ container_ansible_user }}" >/dev/null 2>&1; then
             useradd -m -s /bin/bash "{{ container_ansible_user }}";
             changed=1;
           fi;

           if ! id -nG "{{ container_ansible_user }}" | tr " " "\n" | grep -qx wheel; then
             usermod -aG wheel "{{ container_ansible_user }}";
             changed=1;
           fi;

           echo "{{ container_ansible_user }}:{{ container_ansible_password }}" | chpasswd;

           expected_sudoers="{{ container_ansible_user }} ALL=(ALL) NOPASSWD: ALL";

           if [ ! -f "{{ container_ansible_sudoers_file }}" ] ||
              ! grep -Fxq "$expected_sudoers" "{{ container_ansible_sudoers_file }}"; then
             printf "%s\n" "$expected_sudoers" > "{{ container_ansible_sudoers_file }}";
             chmod 0440 "{{ container_ansible_sudoers_file }}";
             changed=1;
           fi;

           visudo -cf "{{ container_ansible_sudoers_file }}";

           if [ "$changed" -eq 1 ]; then
             echo "ansible user sudo configuration changed";
           else
             echo "ansible user sudo configuration already present";
           fi'
      register: container_ansible_user_config_result
      when:
        - systemd_container_final_info.exists | default(false)
        - systemd_container_final_info.container.State.Running | default(false)
      changed_when: "'ansible user sudo configuration changed' in container_ansible_user_config_result.stdout"
      failed_when: container_ansible_user_config_result.rc | default(1) != 0

    - name: Verify ansible user passwordless sudo inside the container
      community.docker.docker_container_exec:
        container: "{{ systemd_container_name }}"
        command: >-
          /bin/bash -lc
          'su - "{{ container_ansible_user }}" -c "sudo -n true"'
      register: container_ansible_sudo_verify_result
      when:
        - systemd_container_final_info.exists | default(false)
        - systemd_container_final_info.container.State.Running | default(false)
      changed_when: false
      failed_when: container_ansible_sudo_verify_result.rc | default(1) != 0

    - name: Install openssh-server inside the systemd container
      community.docker.docker_container_exec:
        container: "{{ systemd_container_name }}"
        command: >-
          /bin/bash -lc
          'if rpm -q openssh-server >/dev/null 2>&1; then
             echo "openssh-server already installed";
           else
             dnf -y install openssh-server;
             echo "openssh-server installed";
           fi'
      register: container_sshd_install_result
      when:
        - systemd_container_final_info.exists | default(false)
        - systemd_container_final_info.container.State.Running | default(false)
      changed_when: "'openssh-server installed' in container_sshd_install_result.stdout"
      failed_when: container_sshd_install_result.rc | default(1) != 0

    - name: Generate SSH host keys inside the systemd container
      community.docker.docker_container_exec:
        container: "{{ systemd_container_name }}"
        command: >-
          /bin/bash -lc
          'before_count="$(find /etc/ssh -maxdepth 1 -type f -name "ssh_host_*_key" 2>/dev/null | wc -l)";
           ssh-keygen -A;
           after_count="$(find /etc/ssh -maxdepth 1 -type f -name "ssh_host_*_key" 2>/dev/null | wc -l)";
           if [ "$after_count" -gt "$before_count" ]; then
             echo "ssh host keys generated";
           else
             echo "ssh host keys already present";
           fi'
      register: container_ssh_host_keys_result
      when:
        - systemd_container_final_info.exists | default(false)
        - systemd_container_final_info.container.State.Running | default(false)
      changed_when: "'ssh host keys generated' in container_ssh_host_keys_result.stdout"
      failed_when: container_ssh_host_keys_result.rc | default(1) != 0

    - name: Enable and start sshd inside the systemd container
      community.docker.docker_container_exec:
        container: "{{ systemd_container_name }}"
        command: >-
          /bin/bash -lc
          'if systemctl is-enabled sshd >/dev/null 2>&1 &&
              systemctl is-active --quiet sshd; then
             echo "sshd already enabled and running";
           else
             systemctl enable --now sshd;
             echo "sshd enabled and started";
           fi'
      register: container_sshd_enable_start_result
      when:
        - systemd_container_final_info.exists | default(false)
        - systemd_container_final_info.container.State.Running | default(false)
      changed_when: "'sshd enabled and started' in container_sshd_enable_start_result.stdout"
      failed_when: container_sshd_enable_start_result.rc | default(1) != 0

    - name: Verify sshd status inside the systemd container
      community.docker.docker_container_exec:
        container: "{{ systemd_container_name }}"
        command: "systemctl is-active sshd"
      register: container_sshd_status_result
      when:
        - systemd_container_final_info.exists | default(false)
        - systemd_container_final_info.container.State.Running | default(false)
      changed_when: false
      failed_when: false

    - name: Report final systemd container state, hostname, sshd status, and ansible sudo validation
      ansible.builtin.debug:
        msg: >-
          Container {{ systemd_container_name }} running state:
          {{ systemd_container_final_info.container.State.Running | default(false) }};
          configured hostname:
          {{ container_hostname_verify_result.stdout | default('hostname not verified') }};
          sshd status:
          {{ container_sshd_status_result.stdout | default('sshd status not verified') }};
          ansible passwordless sudo validation rc:
          {{ container_ansible_sudo_verify_result.rc | default('not verified') }}